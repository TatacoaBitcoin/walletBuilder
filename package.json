    "clean-ios": "rm -rf ios/build/ ios/Pods/ && pushd ios && pod install && popd",
    "clean-android": "rm -rf android/build/ android/.gradle/ android/app/build/ && pushd android && ./gradlew clean && popd",
    "clean": "rm -rf node_modules/ && yarn install && yarn clean-ios && yarn clean-android"
  },
